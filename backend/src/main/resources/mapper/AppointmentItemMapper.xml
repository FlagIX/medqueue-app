<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.medqueue.mapper.AppointmentItemMapper">

    <select id="queryItemsOfHospital" resultType="com.medqueue.entity.AppointmentItem">
        SELECT * FROM tb_appointment_item WHERE hospital_id = #{hospitalId}
